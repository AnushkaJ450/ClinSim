clean_text <- function(text) { #standardises input text
#ensures that the text only contains uppercase letters
text <- toupper(text) #converts all letters to upper case
#ensures uniform mapping
text <- gsub("[^A-Z]", "", text) #removes any text that's not from A to Z
#replaces it with an empty string
return(text)
}
t_int <- function(text) {    #Converts a string of letters to a numeric representation
#so A = 0, B = 1 ...
chars <- strsplit(text, "")[[1]]    #Splits string into individual characters
t_ints <- as.integer(chartr("ABCDEFGHIJKLMNOPQRSTUVWXYZ",
paste(0:25, collapse=""), chars))
t_ints <- match(chars, LETTERS)- 1L #Finds position of each character in letters
#Subtracts 1 as R indexing starts on 1
return(t_ints)
}
int_t <- function(t_ints) {   #converts the integers back into string
paste(LETTERS[t_ints + 1L], collapse = "") #Combines vector back into a single string
}
caesar_encode <- function(text, shift) {  #Applies the caesar shift
#E(x) = (x + k) mod 26
t_ints <- t_int(clean_text(text))
encoded <- (t_ints + shift) %% 26L
return(int_t(encoded))
}
caesar_decode <- function(ciphertext, shift) { #Does the reverse
#D(x) = (x - k) mod 26
t_ints <- t_int(clean_text(ciphertext))
decoded <- (t_ints- shift + 26L) %% 26L
return(int_t(decoded))
}
caesar_encode("testing", 5)
caesar_decode("yjxynsl", 5)
order0 <- function(text, alpha = 1) {    #Applies laplace smoothing
t_ints <- t_int(clean_text(text)) #Converts text to integers
#Ensures only uppercase letters remain
counts <- rep(0L, 26)
names(counts) <- LETTERS
for (i in seq_along(t_ints)) {
counts[t_ints[i] + 1L] <- counts[t_ints[i] + 1L] + 1L    #Loops over each character
#Adds 1 for R indexing
#Computes the raw frequency count
#Finds the total number of letters and divides count by total to work out probabilities
smoothed <- counts + alpha #Adds alpha to every cell and normalises each row
#Guarantees P > 0 everywhere
probs <- smoothed / sum(smoothed)
return(probs)
}
}
