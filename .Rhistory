## ALL CODE
clean_text <- function(text) {   #standardises input text
text <- toupper(text)            #converts all letters to upper case
text <- gsub("[^A-Z]", "", text) #removes any text that's not A - Z
return(text)
}
#Converts a string of letters to a numeric representation
t_int <- function(text) {
chars <- strsplit(text, "")[[1]]  #Splits string into individual characters
t_ints <- match(chars, LETTERS)- 1L
return(t_ints)
}
#converts the integers back into string
int_t <- function(t_ints) {
paste(LETTERS[t_ints + 1L], collapse = "")
}
#Applies the caesar shift
caesar_encode <- function(text, shift) {
#E(x) = (x + k) mod 26
t_ints <- t_int(clean_text(text))
encoded <- (t_ints + shift) %% 26L
return(int_t(encoded))
}
#Does the reverse
caesar_decode <- function(ciphertext, shift) {
#D(x) = (x - k) mod 26
t_ints <- t_int(clean_text(ciphertext))
decoded <- (t_ints- shift + 26L) %% 26L
return(int_t(decoded))}
order0 <- function(text, alpha = 1) {
t_ints <- t_int(clean_text(text))  #Converts text to integers
counts <- rep(0L, 26)
names(counts) <- LETTERS
for (i in seq_along(t_ints)) {
counts[t_ints[i] + 1L] <- counts[t_ints[i] + 1L] + 1L
}
#Finds the total number of letters and divides count by total to work out probabilities
smoothed <- counts + alpha
probs <- smoothed / sum(smoothed)
return(probs) }
order1 <- function(text, alpha = 1) {
t_ints <- t_int(clean_text(text))
n <- length(t_ints)
counts <- matrix(0L, nrow = 26, ncol = 26,
dimnames = list(LETTERS, LETTERS))
for (i in 1:(n - 1L)) {
from <- t_ints[i] + 1L
to   <- t_ints[i + 1L] + 1L
counts[from, to] <- counts[from, to] + 1L
}
probs <- matrix(0.0, nrow = 26, ncol = 26, #normalises each row
dimnames = list(LETTERS, LETTERS))
for (r in 1:26) {  #computes total outgoing transitions in each row
smoothed <- counts[r, ] + alpha
probs[r, ] <- smoothed / sum(smoothed)
}
return(probs)}
order2 <- function(text, alpha = 1) {
t_ints <- t_int(clean_text(text))
n <- length(t_ints)
counts <- list()
#instead of storing 676 x 26 array we use a list
for (i in 1:(n - 2L)) {
bindex <- paste0(LETTERS[t_ints[i] + 1L], LETTERS[t_ints[i + 1L] + 1L])
#Creates a context string that represents the 2 letters before
nindex <- t_ints[i + 2L] + 1L  #Next letter index
if (is.null(counts[[bindex]])) {
counts[[bindex]] <- rep(0L, 26)
names(counts[[bindex]]) <- LETTERS
}
counts[[bindex]][nindex] <- counts[[bindex]][nindex] + 1L
}
probs <- list()
for (bindex in names(counts)) {
smoothed <- counts[[bindex]] + alpha
probs[[bindex]] <- smoothed / sum(smoothed)
}
return(probs)}
order3 <- function(text, alpha = 1) {
t_ints <- t_int(clean_text(text))
n <- length(t_ints)
counts <- list()
for (i in 1:(n - 3L)) {
bindex <- paste0(LETTERS[t_ints[i]   + 1L],
LETTERS[t_ints[i+1] + 1L],
LETTERS[t_ints[i+2] + 1L])
nindex <- t_ints[i + 3L] + 1L
if (is.null(counts[[bindex]])) {
counts[[bindex]] <- rep(0L, 26)
names(counts[[bindex]]) <- LETTERS
}
counts[[bindex]][nindex] <- counts[[bindex]][nindex] + 1L
}
probs <- list()
for (bindex in names(counts)) {
smoothed <- counts[[bindex]] + alpha
probs[[bindex]] <- smoothed / sum(smoothed)
}
return(probs)}
# uniform modelling for unseen contexts
unseen_prob <- function(alpha = 1) {
p <- rep(alpha / (26 * alpha), 26)
names(p) <- LETTERS
return(p) }
#Score under order-0 model
score_order0 <- function(text, unigram_probs) {
t_ints  <- t_int(clean_text(text))
total <- 0
for (i in seq_along(t_ints)) {
total <- total + log(unigram_probs[t_ints[i] + 1L])
}
return(total)}
#Score under order-1 model
score_order1 <- function(text, trans_matrix) {
t_ints  <- t_int(clean_text(text))
n <- length(t_ints)
if (n < 2) return(-Inf)
total <- 0.0
for (i in 1:(n - 1L)) {
total <- total + log(trans_matrix[t_ints[i] + 1L, t_ints[i + 1L] + 1L])
}
return(total)}
#Score under order-2 model.
#Unseen 2-letter context gives uniform (1/26)
#which is consistent with Laplace.
score_order2 <- function(text, trigram_probs, order1_mat) {
t_ints <- t_int(clean_text(text))
n <- length(t_ints)
if (n < 3) return(-Inf)
unif <- unseen_prob() #uniform vector, from smoothing
total <- 0
for (i in 1:(n - 2L)) {
bindex <- paste0(LETTERS[t_ints[i] + 1L], LETTERS[t_ints[i + 1L] + 1L])
nindex <- t_ints[i + 2L] + 1L
p   <- if (!is.null(trigram_probs[[bindex]])) trigram_probs[[bindex]][nindex] else unif[nindex]
total <- total + log(p)
}
return(total)}
# Score under order-3 model.
# Unseen 3-letter context makes it try 2-letter
#unseen 2-letter makes it uniform.
score_order3 <- function(text, fourgram_probs, trigram_probs, order1_mat) {
t_ints <- t_int(clean_text(text))
n <- length(t_ints)
if (n < 4) return(-Inf)
unif <- unseen_prob()
total <- 0
for (i in 1:(n - 3L)) {
bindex3 <- paste0(LETTERS[t_ints[i]   + 1L],
LETTERS[t_ints[i+1] + 1L],
LETTERS[t_ints[i+2] + 1L])
bindex2 <- paste0(LETTERS[t_ints[i+1] + 1L],
LETTERS[t_ints[i+2] + 1L])
nindex  <- t_ints[i + 3L] + 1L
p <- if (!is.null(fourgram_probs[[bindex3]])) fourgram_probs[[bindex3]][nindex] else
if (!is.null(trigram_probs[[bindex2]]))  trigram_probs[[bindex2]][nindex]  else
unif[nindex]
total <- total + log(p)
}
return(total)}
decode_all_shifts <- function(ciphertext, model_order,
unigram = NULL, order1 = NULL,
order2 = NULL, order3 = NULL) {
scores <- numeric(26)
names(scores) <- as.character(0:25)
for (k in 0:25) {
candidate <- caesar_decode(ciphertext, k)
scores[k + 1L] <- switch(as.character(model_order),
"0" = score_order0(candidate, unigram),
"1" = score_order1(candidate, order1),
"2" = score_order2(candidate, order2, order1),
"3" = score_order3(candidate, order3, order2, order1),
)
}
best_k     <- which.max(scores) - 1L
best_score <- max(scores)
decoded    <- caesar_decode(ciphertext, best_k)
return(list(
best_shift = best_k,
best_score = best_score,
all_scores = scores,
decoded    = decoded
))
}
# Train all four models on War and Peace
uni    <- order0(train_text)
bi     <- order1(train_text)
tri    <- order2(train_text)
four_g <- order3(train_text)
