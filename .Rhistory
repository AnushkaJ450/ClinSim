devtools::build_manual()
acc
set.seed(42)
lengths  <- c(5, 10, 15, 20, 50)
orders   <- c(0, 1, 2, 3)
n_trials <- 200
N_test   <- nchar(test_text)
# accuracy matrix: rows = message lengths, cols = model orders
acc <- matrix(NA, nrow = length(lengths), ncol = length(orders),
dimnames = list(lengths, paste0("Order_", orders)))
for (li in seq_along(lengths)) {
len <- lengths[li]
for (oi in seq_along(orders)) {
ord <- orders[oi]
hits <- 0L
for (trial in 1:n_trials) {
start <- sample(1:(N_test - len), 1)
plain_ints <- t_int(substr(test_text, start, start + len - 1))
true_k <- sample(1:25, 1)
cipher_ints <- (plain_ints + true_k) %% 26L
# try all 26 shifts in integer space
best_k <- 0L
best_s <- -Inf
for (k in 0:25) {
dec <- (cipher_ints - k + 26L) %% 26L
s <- switch(as.character(ord),
"0" = fast_score0(dec, uni),
"1" = fast_score1(dec, bi),
"2" = fast_score2(dec, tri),
"3" = fast_score3(dec, four_g, tri))
if (s > best_s) { best_s <- s; best_k <- k }
}
if (best_k == true_k) hits <- hits + 1L
}
acc[li, oi] <- hits / n_trials
}}
